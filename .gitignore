# =============================================================================
# Data y outputs (no se versionan: pesan demasiado y/o son regenerables)
# =============================================================================
/data/
/outputs/
/output_files/

# Formatos de datos pesados (por si aparecen fuera de /data)
*.csv
*.tsv
*.parquet
*.feather
*.pkl
*.pickle
*.rds
*.RData
*.h5
*.hdf5
*.sqlite
*.db
*.zip
*.tar
*.tar.gz
*.7z
*.rar
*.shp
*.shx
*.dbf
*.gpkg

# Excepciones: archivos pequeños de referencia que SÍ queremos versionar
!docs/**/*.csv
!docs/**/*.tsv

# =============================================================================
# Sistema operativo
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes
ehthumbs.db

# =============================================================================
# R / RStudio
# =============================================================================
.Rhistory
.Rapp.history
.RDataTmp
.Ruserdata
*-Ex.R
/*.tar.gz
/*.Rcheck/
.Rproj.user/
.httr-oauth
*_cache/
/cache/
*.utf8.md
*.knit.md
.Renviron
po/*~
rsconnect/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/
.env

# =============================================================================
# Editores / IDEs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo

# =============================================================================
# Quarto / knitr (cachés y temporales)
# =============================================================================
/_site/
/.quarto/
*_files/_freeze/
