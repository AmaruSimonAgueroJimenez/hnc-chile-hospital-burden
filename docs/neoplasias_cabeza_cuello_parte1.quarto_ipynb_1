        "        ax.plot(sd['year'], sd['asr'], marker='o', linewidth=2.5,\n",
        "                label=SITE_NAMES.get(site, site), markersize=6,\n",
        "                color=SITE_COLORS.get(site, None))\n",
        "    ax.set_ylabel('ASR (per 100,000)', fontsize=11, fontweight='bold')\n",
        "    ax.set_title(f'ASR Trends by Site — {title}', fontsize=12, fontweight='bold')\n",
