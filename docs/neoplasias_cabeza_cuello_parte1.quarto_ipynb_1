        "def classify_lisa(lisa_obj, data):\n",
        "    sig = lisa_obj.p_sim < 0.05\n",
        "    q = lisa_obj.q\n",
        "    labels = ['Not significant'] * len(data)\n",
        "    for i in range(len(data)):\n",
        "        if sig[i]:\n",
        "            if q[i] == 1:\n",
        "                labels[i] = 'High-High (Hot Spot)'\n",
        "            elif q[i] == 2:\n",
        "                labels[i] = 'Low-High'\n",
        "            elif q[i] == 3:\n",
        "                labels[i] = 'Low-Low (Cold Spot)'\n",
        "            elif q[i] == 4:\n",
        "                labels[i] = 'High-Low'\n",
        "    return labels\n",
        "\n",
        "lisa_total = None\n",
        "lisa_by_site = {}\n",
        "\n",
        "if has_spatial_data and pesos is not None:\n",
