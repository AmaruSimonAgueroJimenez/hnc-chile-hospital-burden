        "        df = df.drop(columns=['code_num'])\n",
        "        df['icd_category'] = df['DIAG1'].apply(categorize_head_neck_site)\n",
        "        df = df[df['icd_category'].notna()]\n",
        "        df.rename(columns={\n",
