        "        try:\n",
        "            lisa_total = Moran_Local(gdf_total['asr_total'], pesos)\n",
        "            gdf_total['cluster'] = classify_lisa(lisa_total, gdf_total)\n",
        "            gdf_total['lisa_p'] = lisa_total.p_sim\n",
        "        except:\n",
        "            gdf_total['cluster'] = 'No data'\n",
        "            gdf_total['lisa_p'] = 1.0\n",
        "    else:\n",
        "        gdf_total['cluster'] = 'No data'\n",
        "\n",
        "    for site_code in gdf_by_site:\n",
