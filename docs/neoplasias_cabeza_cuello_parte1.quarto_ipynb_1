        "}\n",
        "\n",
        "egresos_df['GRUPO_EDAD'] = egresos_df['GRUPO_EDAD'].astype(str).str.strip().str.upper()\n",
        "\n",
        "hosp_5year_list = []\n",
        "for year in YEARS:\n",
        "    year_egresos = egresos_df[egresos_df['year'] == year].copy()\n",
        "    year_pop = pop_5year[pop_5year['year'] == year]\n",
        "    for _, row in year_egresos.iterrows():\n",
        "        sex = row['SEXO']\n",
        "        grupo = row['GRUPO_EDAD']\n",
        "        icd_cat = row['icd_category']\n",
        "        age_groups_list = grupo_edad_mapping.get(grupo, [])\n",
        "        if not age_groups_list:\n",
        "            continue\n",
        "        sex_year_pop = year_pop[year_pop['sex'] == sex]\n",
        "        # Compute total population across all 5-year subgroups for this band\n",
        "        total_pop_band = sum([\n",
