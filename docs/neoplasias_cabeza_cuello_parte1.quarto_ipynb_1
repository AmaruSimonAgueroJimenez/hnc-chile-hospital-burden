        "#| label: fig-asr-trends-site\n",
        "#| fig-cap: ASR trends by site — Total, Male, and Female (2010–2024)\n",
        "\n",
        "# Compute ASR by site for each sex separately\n",
        "who_weights_df = pd.DataFrame([\n",
        "    {'age_group': k, 'who_weight': v} for k, v in WHO_STANDARD_POPULATION.items()\n",
        "])\n",
        "\n",
        "def _asr_by_site_sex(hosp_df, pop_df, sex_filter=None, per=100000):\n",
        "    if sex_filter:\n",
        "        h = hosp_df[hosp_df['sex'] == sex_filter].groupby(\n",
        "            ['year', 'age_group', 'icd_category'])['hospitalizations'].sum().reset_index()\n",
        "        p = pop_df[pop_df['sex'] == sex_filter].groupby(\n",
        "            ['year', 'age_group'])['population'].sum().reset_index()\n",
        "    else:\n",
        "        h = hosp_df.groupby(\n",
        "            ['year', 'age_group', 'icd_category'])['hospitalizations'].sum().reset_index()\n",
        "        p = pop_df.groupby(\n",
        "            ['year', 'age_group'])['population'].sum().reset_index()\n",
        "    m = h.merge(p, on=['year', 'age_group'], how='left').dropna(subset=['population'])\n",
        "    m = m[m['population'] > 0]\n",
        "    m['rate'] = (m['hospitalizations'] / m['population']) * per\n",
        "    m = m.merge(who_weights_df, on='age_group', how='left')\n",
        "    m['wr'] = m['rate'] * m['who_weight']\n",
        "    agg = m.groupby(['year', 'icd_category']).agg(\n",
        "        hospitalizations=('hospitalizations', 'sum'), weighted_rate=('wr', 'sum')\n",
        "    ).reset_index()\n",
        "    agg['asr'] = (agg['weighted_rate'] / TOTAL_WHO_WEIGHT).round(2)\n",
        "    return agg[['year', 'icd_category', 'hospitalizations', 'asr']]\n",
        "\n",
        "asr_site_total = _asr_by_site_sex(hosp_by_site, population, sex_filter=None)\n",
        "asr_site_male  = _asr_by_site_sex(hosp_by_site, population, sex_filter='Male')\n",
        "asr_site_female = _asr_by_site_sex(hosp_by_site, population, sex_filter='Female')\n",
        "\n",
        "sites_list = site_summary['icd_category'].tolist()\n",
        "\n",
        "fig, axes = plt.subplots(3, 1, figsize=(18, 16), sharex=True)\n",
        "panel_data = [\n",
