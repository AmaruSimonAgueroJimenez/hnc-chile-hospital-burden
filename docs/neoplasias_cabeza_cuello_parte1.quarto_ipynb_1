        "def assign_age_group(age):\n",
        "    if pd.isna(age) or age is None:\n",
        "        return None\n",
        "    try:\n",
        "        age = int(float(age))\n",
        "    except (ValueError, TypeError):\n",
        "        return None\n",
        "    if age < 0:\n",
        "        return None\n",
        "    if age >= 80:\n",
        "        return '80+'\n",
        "    for start, end in AGE_GROUPS_TUPLES:\n",
        "        if start <= age <= end:\n",
        "            return f\"{start}-{end}\"\n",
        "    return None\n",
        "\n",
        "\n",
        "def categorize_head_neck_site(code):\n",
        "    \"\"\"Categorize ICD-10 code into site-level head and neck neoplasm group (C00-C14, C30-C32).\"\"\"\n",
        "    if not isinstance(code, str) or not code.startswith('C'):\n",
        "        return None\n",
        "    code_upper = code.upper().strip()\n",
        "    # Extract the two-digit numeric part\n",
        "    try:\n",
        "        num = int(code_upper[1:3])\n",
        "    except (ValueError, IndexError):\n",
        "        return None\n",
        "    # Check if it's in head and neck ranges\n",
        "    if (0 <= num <= 14) or (30 <= num <= 32):\n",
        "        if num == 0:\n",
        "            return 'C00'\n",
        "        elif num == 1:\n",
        "            return 'C01'\n",
        "        elif num == 2:\n",
        "            return 'C02'\n",
        "        elif num == 3:\n",
        "            return 'C03'\n",
        "        elif num == 4:\n",
        "            return 'C04'\n",
        "        elif num == 5:\n",
        "            return 'C05'\n",
        "        elif num == 6:\n",
        "            return 'C06'\n",
        "        elif num == 7:\n",
        "            return 'C07'\n",
        "        elif num == 8:\n",
        "            return 'C08'\n",
        "        elif num == 9:\n",
        "            return 'C09'\n",
        "        elif num == 10:\n",
        "            return 'C10'\n",
        "        elif num == 11:\n",
        "            return 'C11'\n",
        "        elif num == 12:\n",
        "            return 'C12'\n",
        "        elif num == 13:\n",
        "            return 'C13'\n",
        "        elif num == 14:\n",
        "            return 'C14'\n",
        "        elif num == 30:\n",
        "            return 'C30'\n",
        "        elif num == 31:\n",
        "            return 'C31'\n",
        "        elif num == 32:\n",
        "            return 'C32'\n",
        "    return None\n",
        "\n",
        "\n",
        "def _normalize_txt(x):\n",
        "    if pd.isna(x):\n",
        "        return None\n",
        "    s = str(x).strip().lower()\n",
        "    repl = str.maketrans({'á': 'a', 'é': 'e', 'í': 'i', 'ó': 'o', 'ú': 'u', 'ñ': 'n'})\n",
        "    return s.translate(repl)\n",
        "\n",
        "\n",
        "def _standardize_sex(x):\n",
        "    if pd.isna(x):\n",
        "        return None\n",
        "    v = _normalize_txt(x)\n",
        "    if v is None:\n",
        "        return None\n",
        "    v = v.replace('.', '').replace('-', ' ').replace('_', ' ').strip()\n",
        "    if v in {'1', 'm', 'male', 'masculino', 'hombre', 'hombres', 'varon', 'varones'}:\n",
        "        return 'Male'\n",
        "    if v in {'2', 'f', 'female', 'femenino', 'mujer', 'mujeres'}:\n",
        "        return 'Female'\n",
        "    return None\n",
        "\n",
        "\n",
        "def normalize_region_to_standard(region_name):\n",
        "    if pd.isna(region_name):\n",
        "        return None\n",
        "    name = str(region_name).strip()\n",
        "    return PARQUET_TO_STANDARD_REGION.get(name, name)\n",
        "\n",
        "\n",
        "def load_population_data(years=YEARS):\n",
        "    candidate_paths = [\n",
        "        str(data_base / 'censo_proyecciones_ano_edad_genero.parquet'),\n",
        "        str(data_base / 'censo_proyecciones_año_edad_genero.parquet'),\n",
        "    ]\n",
        "    pop_file = None\n",
        "    for p in candidate_paths:\n",
        "        if os.path.exists(p):\n",
        "            pop_file = p\n",
        "            break\n",
        "    if pop_file is None:\n",
        "        matches = glob.glob(str(data_base / '**' / 'censo_proyecciones*edad_genero*.parquet'), recursive=True)\n",
        "        pop_file = matches[0] if matches else None\n",
        "    if pop_file is None:\n",
        "        raise FileNotFoundError(\"Population projections file not found.\")\n",
        "\n",
        "    df = pd.read_parquet(pop_file, engine=\"pyarrow\")\n",
        "    df.columns = [str(c).strip() for c in df.columns]\n",
        "    cols_norm = {_normalize_txt(c): c for c in df.columns}\n",
        "\n",
        "    year_col = cols_norm.get('ano') or cols_norm.get('anio') or cols_norm.get('year')\n",
