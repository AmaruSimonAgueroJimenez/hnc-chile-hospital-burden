        "            'GLOSA_REGION_RESIDENCIA': 'region',\n",
        "            'GLOSA_COMUNA_RESIDENCIA': 'comuna'\n",
        "        }, inplace=True)\n",
        "        all_egresos.append(df)\n",
        "    except Exception:\n",
