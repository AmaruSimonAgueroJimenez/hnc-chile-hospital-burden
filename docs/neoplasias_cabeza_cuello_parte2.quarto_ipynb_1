        "            df_head_neck['hospital_id'] = df_head_neck[hcol].astype(str)\n",
        "            break\n",
        "    else:\n",
        "        df_head_neck['hospital_id'] = '1'  # single cluster fallback\n",
        "\n",
        "df_head_neck['year_factor'] = df_head_neck['year'].astype(str)"
